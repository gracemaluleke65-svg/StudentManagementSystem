@using StudentManagementSystem.Services
@model IEnumerable<StudentManagementSystem.Models.Student>
@inject AzureBlobStorageService BlobStorageService

@if (Model != null && Model.Any())
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-primary">
                <tr>
                    <th style="width: 80px;">Profile</th>
                    <th>Student Info</th>
                    <th>Contact</th>
                    <th style="width: 120px;">Status</th>
                    <th style="width: 150px;" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model)
                {
                    var sasUrl = !string.IsNullOrEmpty(student.ProfileImageUrl) ?
                        BlobStorageService.GetBlobSasUri(BlobStorageService.GetBlobNameFromUrl(student.ProfileImageUrl)) : null;
                    
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(sasUrl))
                            {
                                <img src="@sasUrl" alt="@student.FullName" class="rounded-circle" style="width: 50px; height: 50px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="bg-secondary rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                    <i class="fa fa-user-graduate text-white"></i>
                                </div>
                            }
                        </td>
                        <td>
                            <strong>@student.FullName</strong><br />
                            <small class="text-muted">ID: @(student.Id?.Length > 8 ? student.Id.Substring(0, 8) : student.Id ?? "N/A")</small>
                        </td>
                        <td>
                            <small><i class="fa fa-envelope text-primary me-1"></i> @student.Email</small><br />
                            <small><i class="fa fa-phone text-success me-1"></i> @student.MobileNumber</small>
                        </td>
                        <td>
                            @if (student.EnrolmentStatus == "Active")
                            {
                                <span class="badge bg-success">
                                    <i class="fa fa-check-circle me-1"></i> Active
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    <i class="fa fa-pause-circle me-1"></i> Inactive
                                </span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@student.Id" class="btn btn-sm btn-warning me-1" title="Edit">
                                <i class="fa fa-edit"></i>
                            </a>
                            <button type="button" class="btn btn-sm btn-secondary me-1" onclick="confirmSoftDelete('@student.Id', '@student.FullName.Replace("'", "\\'")')" title="Archive">
                                <i class="fa fa-archive"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-danger" onclick="confirmPermanentDelete('@student.Id', '@student.FullName.Replace("'", "\\'")')" title="Permanent Delete">
                                <i class="fa fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="text-center py-5">
        <div class="bg-light rounded p-5">
            <i class="fa fa-users fa-4x text-primary mb-3"></i>
            <h3>No Students Found</h3>
            <p class="text-muted">No student records match your search criteria or the database is empty.</p>
            <a asp-action="Create" class="btn btn-primary mt-3">
                <i class="fa fa-plus me-2"></i>Add Your First Student
            </a>
        </div>
    </div>
}