                                    <p class="mb-0">Millisecond response times with Cosmos DB's global distribution and automatic indexing.</p>
                                </div>
                                <div class="col-12 wow zoomIn" data-wow-delay="0.6s">
                                    <div class="bg-primary rounded d-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                                        <i class="fa fa-chart-line text-white"></i>
                                    </div>
                                    <h4>Real-time Analytics</h4>
                                    <p class="mb-0">Interactive dashboards with enrollment trends, demographics, and performance metrics.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4 wow zoomIn" data-wow-delay="0.9s" style="min-height: 350px;">
                            <div class="position-relative h-100">
                                <img class="position-absolute w-100 h-100 rounded wow zoomIn" data-wow-delay="0.1s" src="~/img/feature.jpg" style="object-fit: cover;">
                                </div>
                            </div>
                            <div class="col-lg-4">
                                <div class="row g-5">
                                    <div class="col-12 wow zoomIn" data-wow-delay="0.4s">
                                        <div class="bg-primary rounded d-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                                            <i class="fa fa-shield-alt text-white"></i>
                                        </div>
                                        <h4>Bank-Level Security</h4>
                                        <p class="mb-0">OAuth 2.0 authentication with Google/GitHub, plus SAS tokens for secure file access.</p>
                                    </div>
                                    <div class="col-12 wow zoomIn" data-wow-delay="0.8s">
                                        <div class="bg-primary rounded d-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                                            <i class="fa fa-cloud-upload-alt text-white"></i>
                                        </div>
                                        <h4>Auto-scaling</h4>
                                        <p class="mb-0">Automatically scales with demand. Pay only for what you use with Azure's consumption model.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Features End -->
                <!-- Service Start -->
                <div class="container-fluid py-5 wow fadeInUp" data-wow-delay="0.1s">
                    <div class="container py-5">
                        <div class="section-title text-center position-relative pb-3 mb-5 mx-auto" style="max-width: 600px;">
                            <h5 class="fw-bold text-primary text-uppercase">Azure Services</h5>
                            <h1 class="mb-0">Built on World-Class Infrastructure</h1>
                        </div>
                        <div class="row g-5">
                            <div class="col-lg-4 col-md-6 wow zoomIn" data-wow-delay="0.3s">
                                <div class="service-item bg-light rounded d-flex flex-column align-items-center justify-content-center text-center">
                                    <div class="service-icon">
                                        <i class="fa fa-database text-white"></i>
                                    </div>
                                    <h4 class="mb-3">Azure Cosmos DB</h4>
                                    <p class="m-0">Globally distributed, multi-model database with millisecond response times and automatic indexing.</p>
                                    <span class="mt-3 badge bg-primary">99.999% SLA</span>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6 wow zoomIn" data-wow-delay="0.6s">
                                <div class="service-item bg-light rounded d-flex flex-column align-items-center justify-content-center text-center">
                                    <div class="service-icon">
                                        <i class="fa fa-cloud-upload-alt text-white"></i>
                                    </div>
                                    <h4 class="mb-3">Azure Blob Storage</h4>
                                    <p class="m-0">Secure, scalable object storage for student profile images with SAS token authentication.</p>
                                    <span class="mt-3 badge bg-success">Hot Tier</span>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6 wow zoomIn" data-wow-delay="0.9s">
                                <div class="service-item bg-light rounded d-flex flex-column align-items-center justify-content-center text-center">
                                    <div class="service-icon">
                                        <i class="fab fa-microsoft text-white"></i>
                                    </div>
                                    <h4 class="mb-3">Microsoft Entra ID</h4>
                                    <p class="m-0">OAuth 2.0 authentication with Google and GitHub integration for secure, passwordless login.</p>
                                    <span class="mt-3 badge bg-warning">OAuth 2.0</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Service End -->
